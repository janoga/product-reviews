# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=product_reviews
POSTGRES_HOST_PORT=5433

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/product_reviews"

# ── MinIO (local S3-compatible storage) ───────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=product-images
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false

# Public URL the browser uses to load images from MinIO
NEXT_PUBLIC_STORAGE_URL="http://localhost:9000/product-images"
